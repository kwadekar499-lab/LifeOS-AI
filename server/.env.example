# Application
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# Security
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRY=7d
BCRYPT_ROUNDS=12

# Database
DATABASE_URL="postgresql://lifeos:lifeos_password@localhost:5432/lifeos_db?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Request Size Limits
MAX_REQUEST_SIZE=10mb
MAX_JSON_PAYLOAD=5mb

# Logging
LOG_LEVEL=info

# Health Check
HEALTH_CHECK_TIMEOUT=5000

# Swagger
SWAGGER_ENABLED=true
SWAGGER_TITLE=LifeOS AI API
SWAGGER_DESCRIPTION=LifeOS AI Backend API Documentation
SWAGGER_VERSION=1.0.0